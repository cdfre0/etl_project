# .env.example — copy to .env and fill in secrets
# Do NOT commit your real .env (this repo's .gitignore already excludes .env)

# --- Azure Data Lake (ADLS Gen2) ---
# Get this from Azure Portal → Storage accounts → <your-account> → Access keys → Connection string
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT_NAME;AccountKey=YOUR_ACCOUNT_KEY;EndpointSuffix=core.windows.net"

# --- Kafka / Event Hubs ---
# Use local Kafka for development: set KAFKA_USE_EVENT_HUBS=false and KAFKA_BOOTSTRAP_SERVERS=kafka:29092
# For Azure Event Hubs set KAFKA_USE_EVENT_HUBS=true and provide both bootstrap servers and connection string
KAFKA_USE_EVENT_HUBS="false"
KAFKA_BOOTSTRAP_SERVERS="kafka:29092"
# When using Event Hubs, provide the full connection string (namespace-level or entity-level). Example:
# KAFKA_CONNECTION_STRING="Endpoint=sb://<NAMESPACE>.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=<KEY>"
KAFKA_CONNECTION_STRING=""

# --- Runtime flags (optional) ---
KAFKA_ENABLED="true"
SKIP_IF_EXISTS="false"
SKIP_IF_EXISTS_HOURS="24"

# --- Optional topic overrides ---
#KAFKA_TOPIC_DICTIONARIES="bronze-dictionaries"
#KAFKA_TOPIC_CASES="bronze-cases"
#KAFKA_CONSUMER_GROUP="bronze-consumer"
